@page
@model SmartEdu.RazorWeb.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container mt-5">
    <div class="row justify-content-center">

        <div class="col-md-4">

            <h3 class="text-center mb-4">
                SmartEdu Login
            </h3>

            <form method="post">

                <div class="mb-3">
                    <label>Tên đăng nhập</label>
                    <input asp-for="Username"
                           class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Mật khẩu</label>
                    <input asp-for="Password"
                           type="password"
                           class="form-control" />
                </div>

                <button type="submit"
                        class="btn btn-primary w-100">
                    Đăng nhập
                </button>

                <div class="text-danger mt-3">
                    @Model.ErrorMessage
                </div>

            </form>

        </div>

    </div>
</div>