@page
@model SmartEdu.RazorWeb.Pages.Account.ChangePasswordModel
@{
    Layout = "~/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Đổi mật khẩu";
}

<style>
    .se-pwd-wrap {
        display: flex;
        justify-content: center;
        padding: 48px 16px;
    }

    .se-pwd-card {
        width: 100%;
        max-width: 420px;
        background: #fff;
        border: 1px solid #E2E8F0;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(15,27,45,0.06);
        padding: 2.25rem 2rem;
    }

    .se-pwd-icon {
        width: 46px;
        height: 46px;
        border-radius: 12px;
        background: #E6F1FB;
        color: #185FA5;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 18px;
    }

        .se-pwd-icon svg {
            width: 22px;
            height: 22px;
            stroke: currentColor;
            fill: none;
        }

    .se-pwd-title {
        font-size: 18px;
        font-weight: 600;
        color: #0F1B2D;
        margin-bottom: 6px;
        line-height: 1.4;
    }

    .se-pwd-sub {
        font-size: 13px;
        color: #6B7B8D;
        margin-bottom: 1.75rem;
        line-height: 1.6;
    }

    .se-field {
        margin-bottom: 1.1rem;
    }

    .se-label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: #3D4F63;
        margin-bottom: 6px;
    }

    .se-pwd-card .form-control {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid #D8E2EE;
        border-radius: 10px;
        font-size: 14px;
        color: #1A2A3A;
        background: #F7FAFD;
        outline: none;
        transition: border-color 0.15s, box-shadow 0.15s;
        box-shadow: none;
    }

        .se-pwd-card .form-control:focus {
            border-color: #4A90E2;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(74,144,226,0.12);
        }

    .se-field-error {
        font-size: 12px;
        color: #C0392B;
        margin-top: 5px;
        display: block;
    }

    .se-btn-pwd {
        width: 100%;
        padding: 11px;
        background: #4A90E2;
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        margin-top: 0.4rem;
        transition: background 0.15s;
        letter-spacing: 0.2px;
    }

        .se-btn-pwd:hover {
            background: #2f76cc;
        }

        .se-btn-pwd:active {
            transform: scale(0.99);
        }

    .se-alert {
        padding: 11px 15px;
        border-radius: 10px;
        font-size: 13px;
        display: flex;
        align-items: flex-start;
        gap: 9px;
        margin-bottom: 1.25rem;
    }

        .se-alert svg {
            width: 16px;
            height: 16px;
            fill: none;
            stroke: currentColor;
            flex-shrink: 0;
            margin-top: 1px;
        }

    .se-alert-danger {
        background: #FCEBEB;
        color: #A32D2D;
        border: 1px solid #F7C1C1;
    }
</style>

<div class="se-pwd-wrap">
    <div class="se-pwd-card">
        <div class="se-pwd-icon">
            <svg viewBox="0 0 24 24" stroke-width="1.8"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
        </div>

        <div class="se-pwd-title">Đổi mật khẩu</div>
        <p class="se-pwd-sub">Bạn cần đổi mật khẩu trước khi tiếp tục sử dụng hệ thống.</p>

        @if (Model.ErrorMessage != null)
        {
            <div class="se-alert se-alert-danger">
                <svg viewBox="0 0 24 24" stroke-width="1.8">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="8" x2="12" y2="12" />
                    <line x1="12" y1="16" x2="12.01" y2="16" />
                </svg>
                @Model.ErrorMessage
            </div>
        }

        <form method="post">
            <div class="se-field">
                <label asp-for="Input.OldPassword" class="se-label">Mật khẩu hiện tại</label>
                <input asp-for="Input.OldPassword" type="password" class="form-control" placeholder="Nhập mật khẩu hiện tại" />
                <span asp-validation-for="Input.OldPassword" class="se-field-error"></span>
            </div>

            <div class="se-field">
                <label asp-for="Input.NewPassword" class="se-label">Mật khẩu mới</label>
                <input asp-for="Input.NewPassword" type="password" class="form-control" placeholder="Nhập mật khẩu mới" />
                <span asp-validation-for="Input.NewPassword" class="se-field-error"></span>
            </div>

            <div class="se-field">
                <label asp-for="Input.ConfirmPassword" class="se-label">Xác nhận mật khẩu mới</label>
                <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Nhập lại mật khẩu mới" />
                <span asp-validation-for="Input.ConfirmPassword" class="se-field-error"></span>
            </div>

            <button type="submit" class="se-btn-pwd">Đổi mật khẩu</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}