@page
@model SmartEdu.RazorWeb.Pages.Subjects.ManageModel
@{
    ViewData["Title"] = "Manage Subject";
}

<style>
    .se-up-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 22px;
    }

        .se-up-header svg {
            width: 24px;
            height: 24px;
            stroke: #4A90E2;
            fill: none;
        }

        .se-up-header h2 {
            font-size: 20px;
            font-weight: 600;
            color: #0F1B2D;
            margin: 0;
        }

    .se-card {
        border: 1px solid #E2E8F0;
        border-radius: 14px;
        background: #fff;
        margin-bottom: 16px;
        overflow: hidden;
    }

    .se-card-head {
        padding: 11px 16px;
        border-bottom: 1px solid #E2E8F0;
        font-size: 11px;
        font-weight: 600;
        color: #6B7B8D;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
        gap: 7px;
        background: #F8FAFC;
    }

        .se-card-head svg {
            width: 15px;
            height: 15px;
            stroke: #4A90E2;
            fill: none;
        }

    .se-card-body {
        padding: 18px;
    }

    .se-two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 16px;
    }

    .se-alert {
        padding: 11px 15px;
        border-radius: 10px;
        font-size: 13px;
        display: flex;
        align-items: flex-start;
        gap: 9px;
        margin-bottom: 14px;
    }

        .se-alert svg {
            width: 16px;
            height: 16px;
            fill: none;
            stroke: currentColor;
            flex-shrink: 0;
            margin-top: 1px;
        }

    .se-alert-success {
        background: #EAF3DE;
        color: #3B6D11;
        border: 1px solid #C0DD97;
    }

    .se-alert-danger {
        background: #FCEBEB;
        color: #A32D2D;
        border: 1px solid #F7C1C1;
    }

    .se-table-wrap {
        overflow-x: auto;
    }

        .se-table-wrap table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        .se-table-wrap thead tr {
            background: #F8FAFC;
            border-bottom: 1px solid #E2E8F0;
        }

        .se-table-wrap th {
            padding: 9px 16px;
            font-size: 11px;
            font-weight: 600;
            color: #6B7B8D;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-align: left;
        }

        .se-table-wrap tbody tr {
            border-bottom: 1px solid #F0F4F8;
            transition: background 0.1s;
        }

            .se-table-wrap tbody tr:last-child {
                border-bottom: none;
            }

            .se-table-wrap tbody tr:hover {
                background: #F4F8FC;
            }

        .se-table-wrap td {
            padding: 11px 16px;
            vertical-align: middle;
            color: #1A2A3A;
        }

    .se-user-cell {
        display: flex;
        align-items: center;
        gap: 9px;
    }

    .se-avatar {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: #E6F1FB;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 600;
        color: #185FA5;
        flex-shrink: 0;
    }

    .se-user-name {
        font-size: 13px;
        font-weight: 500;
        color: #1A2A3A;
    }

    .se-muted-sm {
        font-size: 12px;
        color: #AAB4C0;
    }

    .se-badge {
        font-size: 11px;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 500;
        white-space: nowrap;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

        .se-badge svg {
            width: 11px;
            height: 11px;
            stroke: currentColor;
            fill: none;
        }

    .se-badge-leader {
        background: #EAF3DE;
        color: #3B6D11;
    }

    .se-btn-row {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        align-items: center;
    }

    .se-btn-sm {
        padding: 5px 11px;
        font-size: 12px;
        font-weight: 500;
        border-radius: 8px;
        cursor: pointer;
        border: 1px solid #D1DCE8;
        background: #fff;
        color: #1A2A3A;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        transition: background 0.1s, border-color 0.1s, color 0.1s;
        white-space: nowrap;
    }

        .se-btn-sm svg {
            width: 13px;
            height: 13px;
            stroke: currentColor;
            fill: none;
        }

        .se-btn-sm:hover {
            background: #F4F8FC;
        }

    .se-btn-leader {
        border-color: #B5D4F4;
        color: #185FA5;
    }

        .se-btn-leader:hover {
            background: #E6F1FB;
        }

    .se-btn-assign {
        border-color: #9FE1CB;
        color: #0F6E56;
    }

        .se-btn-assign:hover {
            background: #E1F5EE;
        }

    .se-btn-danger {
        border-color: #F7C1C1;
        color: #A32D2D;
    }

        .se-btn-danger:hover {
            background: #FCEBEB;
        }

    .se-field-label {
        display: block;
        font-size: 12px;
        font-weight: 500;
        color: #3D4F63;
        margin-bottom: 6px;
    }

    .se-card-body input[type="file"] {
        padding: 8px 13px;
        border: 1px solid #D1DCE8;
        border-radius: 10px;
        font-size: 13px;
        color: #1A2A3A;
        background: #F8FAFC;
        width: 100%;
        max-width: 420px;
        cursor: pointer;
        display: block;
        margin-bottom: 12px;
    }

    .se-btn-primary {
        padding: 7px 16px;
        background: #4A90E2;
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: background 0.12s;
    }

        .se-btn-primary:hover {
            background: #2f76cc;
        }

        .se-btn-primary svg {
            width: 13px;
            height: 13px;
            stroke: #fff;
            fill: none;
        }

    @@media (max-width: 768px) {
        .se-two-col {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="se-up-header">
    <svg viewBox="0 0 24 24" stroke-width="1.8">
        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
    </svg>
    <h2>Manage Subject</h2>
</div>

<input type="hidden" asp-for="SubjectId" />

@if (TempData["ErrorMessage"] != null)
{
    <div class="se-alert se-alert-danger">
        <svg viewBox="0 0 24 24" stroke-width="1.8"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
        @TempData["ErrorMessage"]
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="se-alert se-alert-success">
        <svg viewBox="0 0 24 24" stroke-width="1.8"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
        @TempData["SuccessMessage"]
    </div>
}

<div class="se-two-col">
    <!-- Assigned Lecturers -->
    <div class="se-card">
        <div class="se-card-head">
            <svg viewBox="0 0 24 24" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><polyline points="16 11 18 13 22 9" /></svg>
            Giảng viên đã phân công
        </div>
        <div class="se-table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Giảng viên</th>
                        <th>Username</th>
                        <th>Vai trò</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var l in Model.AssignedLecturers)
                    {
                        var initials = string.Concat(l.FullName.Split(' ')
                            .Where(w => !string.IsNullOrEmpty(w))
                            .Take(2)
                            .Select(w => w[0].ToString().ToUpper()));

                        <tr>
                            <td>
                                <div class="se-user-cell">
                                    <div class="se-avatar">@initials</div>
                                    <div class="se-user-name">@l.FullName</div>
                                </div>
                            </td>
                            <td><span class="se-muted-sm">@l.Username</span></td>
                            <td>
                                @if (l.IsLeader)
                                {
                                    <span class="se-badge se-badge-leader">
                                        <svg viewBox="0 0 24 24" stroke-width="2"><polyline points="20 6 9 17 4 12" /></svg>
                                        Leader
                                    </span>
                                }
                                else
                                {
                                    <span class="se-muted-sm">—</span>
                                }
                            </td>
                            <td>
                                <div class="se-btn-row">
                                    @if (!l.IsLeader && !Model.HasLeader)
                                    {
                                        <form method="post" asp-page-handler="AssignLecturer" class="d-inline">
                                            <input type="hidden" name="lecturerId" value="@l.Id" />
                                            <input type="hidden" name="SubjectId" value="@Model.SubjectId" />
                                            <input type="hidden" name="isLeader" value="true" />
                                            <button type="submit" class="se-btn-sm se-btn-leader">
                                                <svg viewBox="0 0 24 24" stroke-width="1.8"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
                                                Set Leader
                                            </button>
                                        </form>
                                    }
                                    <form method="post" asp-page-handler="RemoveLecturer" class="d-inline">
                                        <input type="hidden" name="lecturerId" value="@l.Id" />
                                        <input type="hidden" name="SubjectId" value="@Model.SubjectId" />
                                        <button type="submit" class="se-btn-sm se-btn-danger">
                                            <svg viewBox="0 0 24 24" stroke-width="1.8"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14H6L5 6" /><path d="M10 11v6M14 11v6" /><path d="M9 6V4h6v2" /></svg>
                                            Xóa
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Available Lecturers -->
    <div class="se-card">
        <div class="se-card-head">
            <svg viewBox="0 0 24 24" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><line x1="19" y1="8" x2="19" y2="14" /><line x1="22" y1="11" x2="16" y2="11" /></svg>
            Giảng viên chưa phân công
        </div>
        <div class="se-table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Giảng viên</th>
                        <th>Username</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var l in Model.NotAssignedLecturers)
                    {
                        var initials = string.Concat(l.FullName.Split(' ')
                            .Where(w => !string.IsNullOrEmpty(w))
                            .Take(2)
                            .Select(w => w[0].ToString().ToUpper()));

                        <tr>
                            <td>
                                <div class="se-user-cell">
                                    <div class="se-avatar">@initials</div>
                                    <div class="se-user-name">@l.FullName</div>
                                </div>
                            </td>
                            <td><span class="se-muted-sm">@l.Username</span></td>
                            <td>
                                <form method="post" asp-page-handler="AssignLecturer" class="d-inline">
                                    <input type="hidden" name="lecturerId" value="@l.Id" />
                                    <input type="hidden" name="SubjectId" value="@Model.SubjectId" />
                                    <input type="hidden" name="isLeader" value="false" />
                                    <button type="submit" class="se-btn-sm se-btn-assign">
                                        <svg viewBox="0 0 24 24" stroke-width="1.8"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                                        Assign
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Import Students -->
<div class="se-card">
    <div class="se-card-head">
        <svg viewBox="0 0 24 24" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="17 8 12 3 7 8" /><line x1="12" y1="3" x2="12" y2="15" /></svg>
        Import sinh viên (Excel)
    </div>
    <div class="se-card-body">
        <form method="post" enctype="multipart/form-data" asp-page-handler="ImportStudents">
            <input type="hidden" name="SubjectId" value="@Model.SubjectId" />
            <label class="se-field-label">Chọn file Excel (.xlsx, .xls)</label>
            <input type="file" name="file" accept=".xlsx,.xls" />
            <button type="submit" class="se-btn-primary">
                <svg viewBox="0 0 24 24" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="17 8 12 3 7 8" /><line x1="12" y1="3" x2="12" y2="15" /></svg>
                Import
            </button>
        </form>
    </div>
</div>