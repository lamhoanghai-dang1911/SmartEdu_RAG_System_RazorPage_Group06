@page
@model SmartEdu.RazorWeb.Pages.Subjects.IndexModel
@{
    ViewData["Title"] = "Subjects";
}

@if (ViewData["OpenEditModal"] as string == "true")
{
    <script>
        var editModal = new bootstrap.Modal(document.getElementById('editModal'));
        editModal.show();
    </script>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Subjects</h2>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">Create New</button>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}


<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Created</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model.Subjects)
        {
            <tr>
                <td>@s.Name</td>
                <td>@s.Description</td>
                <td>@s.CreatedAt.ToString("yyyy-MM-dd")</td>
                <td>
                    <button class="btn btn-sm btn-outline-secondary me-2" data-bs-toggle="modal" data-bs-target="#editModal" data-id="@s.Id" data-name="@s.Name" data-desc="@s.Description">Update</button>
                    <form method="post" asp-page-handler="Delete" class="d-inline">
                        <input type="hidden" name="id" value="@s.Id" />
                        <button class="btn btn-sm btn-danger">Delete</button>
                    </form>
                    <a class="btn btn-sm btn-outline-info ms-2" asp-page="/Subjects/Manage" asp-route-SubjectId="@s.Id">Assign</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@* Create Modal *@
<div class="modal fade" id="createModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Create">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Create Subject</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input class="form-control" name="Name" value="@Model.Name" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" name="Description">@Model.Description</textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

@if (ViewData["OpenCreateModal"] as string == "true")
{
    <script>
        var createModal = new bootstrap.Modal(document.getElementById('createModal'));
        createModal.show();
    </script>
}

@* Edit Modal *@
<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Update">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Edit Subject</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="EditSubject.Id" id="edit-id" name="EditSubject.Id" />
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input class="form-control" asp-for="EditSubject.Name" id="edit-name" name="EditSubject.Name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" asp-for="EditSubject.Description" id="edit-desc" name="EditSubject.Description"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var editModal = document.getElementById('editModal')
        editModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget
            var id = button.getAttribute('data-id')
            var name = button.getAttribute('data-name')
            var desc = button.getAttribute('data-desc')

            document.getElementById('edit-id').value = id
            document.getElementById('edit-name').value = name
            document.getElementById('edit-desc').value = desc
        })
    </script>
}
