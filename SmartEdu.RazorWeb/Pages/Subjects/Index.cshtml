@page
@model SmartEdu.RazorWeb.Pages.Subjects.IndexModel
@{
    ViewData["Title"] = "Subjects";
}

@if (ViewData["OpenEditModal"] as string == "true")
{
    <script>
        var editModal = new bootstrap.Modal(document.getElementById('editModal'));
        editModal.show();
    </script>
}

<style>
    .se-up-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 22px;
    }

        .se-up-header svg {
            width: 24px;
            height: 24px;
            stroke: #4A90E2;
            fill: none;
        }

        .se-up-header h2 {
            font-size: 20px;
            font-weight: 600;
            color: #0F1B2D;
            margin: 0;
        }

    .se-card {
        border: 1px solid #E2E8F0;
        border-radius: 14px;
        background: #fff;
        margin-bottom: 16px;
        overflow: hidden;
    }

    .se-card-head {
        padding: 11px 16px;
        border-bottom: 1px solid #E2E8F0;
        font-size: 11px;
        font-weight: 600;
        color: #6B7B8D;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: #F8FAFC;
    }

    .se-card-head-left {
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .se-card-head svg {
        width: 15px;
        height: 15px;
        stroke: #4A90E2;
        fill: none;
    }

    .se-alert {
        padding: 11px 15px;
        border-radius: 10px;
        font-size: 13px;
        display: flex;
        align-items: flex-start;
        gap: 9px;
        margin-bottom: 14px;
    }

        .se-alert svg {
            width: 16px;
            height: 16px;
            fill: none;
            stroke: currentColor;
            flex-shrink: 0;
            margin-top: 1px;
        }

    .se-alert-success {
        background: #EAF3DE;
        color: #3B6D11;
        border: 1px solid #C0DD97;
    }

    .se-table-wrap {
        overflow-x: auto;
    }

        .se-table-wrap table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        .se-table-wrap thead tr {
            background: #F8FAFC;
            border-bottom: 1px solid #E2E8F0;
        }

        .se-table-wrap th {
            padding: 9px 16px;
            font-size: 11px;
            font-weight: 600;
            color: #6B7B8D;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-align: left;
        }

        .se-table-wrap tbody tr {
            border-bottom: 1px solid #F0F4F8;
            transition: background 0.1s;
        }

            .se-table-wrap tbody tr:last-child {
                border-bottom: none;
            }

            .se-table-wrap tbody tr:hover {
                background: #F4F8FC;
            }

        .se-table-wrap td {
            padding: 11px 16px;
            vertical-align: middle;
            color: #1A2A3A;
        }

    .se-subject-cell {
        display: flex;
        align-items: center;
        gap: 9px;
    }

    .se-subject-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: #E6F1FB;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .se-subject-icon svg {
            width: 16px;
            height: 16px;
            stroke: #4A90E2;
            fill: none;
        }

    .se-subject-name {
        font-size: 13px;
        font-weight: 500;
        color: #1A2A3A;
    }

    .se-muted-sm {
        font-size: 12px;
        color: #AAB4C0;
    }

    .se-btn-row {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        align-items: center;
    }

    .se-btn-sm {
        padding: 5px 11px;
        font-size: 12px;
        font-weight: 500;
        border-radius: 8px;
        cursor: pointer;
        border: 1px solid #D1DCE8;
        background: #fff;
        color: #1A2A3A;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        transition: background 0.1s, border-color 0.1s, color 0.1s;
        text-decoration: none;
        white-space: nowrap;
    }

        .se-btn-sm svg {
            width: 13px;
            height: 13px;
            stroke: currentColor;
            fill: none;
        }

        .se-btn-sm:hover {
            background: #F4F8FC;
        }

    .se-btn-edit {
        border-color: #B5D4F4;
        color: #185FA5;
    }

        .se-btn-edit:hover {
            background: #E6F1FB;
        }

    .se-btn-danger {
        border-color: #F7C1C1;
        color: #A32D2D;
    }

        .se-btn-danger:hover {
            background: #FCEBEB;
        }

    .se-btn-assign {
        border-color: #9FE1CB;
        color: #0F6E56;
    }

        .se-btn-assign:hover {
            background: #E1F5EE;
        }

    .se-btn-primary {
        padding: 7px 16px;
        background: #4A90E2;
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: background 0.12s;
    }

        .se-btn-primary:hover {
            background: #2f76cc;
        }

        .se-btn-primary svg {
            width: 13px;
            height: 13px;
            stroke: #fff;
            fill: none;
        }

    /* Modal overrides */
    .modal-content {
        border: 1px solid #E2E8F0;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: none;
    }

    .modal-header {
        padding: 13px 18px;
        background: #F8FAFC;
        border-bottom: 1px solid #E2E8F0;
    }

        .modal-header .modal-title {
            font-size: 14px;
            font-weight: 600;
            color: #0F1B2D;
        }

    .modal-body {
        padding: 18px;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .modal-footer {
        padding: 12px 18px;
        background: #F8FAFC;
        border-top: 1px solid #E2E8F0;
        display: flex;
        justify-content: flex-end;
        gap: 8px;
    }

    .se-field-label {
        display: block;
        font-size: 12px;
        font-weight: 500;
        color: #3D4F63;
        margin-bottom: 6px;
    }

    .modal-body .form-control {
        padding: 9px 13px;
        border: 1px solid #D1DCE8;
        border-radius: 10px;
        font-size: 13px;
        color: #1A2A3A;
        background: #F8FAFC;
        outline: none;
        transition: border-color 0.12s, box-shadow 0.12s;
        box-shadow: none;
        width: 100%;
    }

        .modal-body .form-control:focus {
            border-color: #4A90E2;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(74, 144, 226, 0.10);
        }

    .modal-body textarea.form-control {
        resize: vertical;
        min-height: 90px;
    }

    .se-btn-secondary {
        padding: 7px 16px;
        background: #fff;
        color: #3D4F63;
        border: 1px solid #D1DCE8;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.12s;
    }

        .se-btn-secondary:hover {
            background: #F4F8FC;
        }
</style>

<div class="se-up-header">
    <svg viewBox="0 0 24 24" stroke-width="1.8">
        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
    </svg>
    <h2>Subjects</h2>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="se-alert se-alert-success">
        <svg viewBox="0 0 24 24" stroke-width="1.8"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
        @TempData["SuccessMessage"]
    </div>
}

<div class="se-card">
    <div class="se-card-head">
        <div class="se-card-head-left">
            <svg viewBox="0 0 24 24" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" /></svg>
            Danh sách môn học
        </div>
        <button class="se-btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">
            <svg viewBox="0 0 24 24" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
            Thêm mới
        </button>
    </div>

    <div class="se-table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Môn học</th>
                    <th>Mô tả</th>
                    <th>Ngày tạo</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.Subjects)
                {
                    <tr>
                        <td>
                            <div class="se-subject-cell">
                                <div class="se-subject-icon">
                                    <svg viewBox="0 0 24 24" stroke-width="1.8"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" /></svg>
                                </div>
                                <div class="se-subject-name">@s.Name</div>
                            </div>
                        </td>
                        <td><span class="se-muted-sm">@s.Description</span></td>
                        <td><span class="se-muted-sm">@s.CreatedAt.ToString("yyyy-MM-dd")</span></td>
                        <td>
                            <div class="se-btn-row">
                                <button class="se-btn-sm se-btn-edit"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editModal"
                                        data-id="@s.Id"
                                        data-name="@s.Name"
                                        data-desc="@s.Description">
                                    <svg viewBox="0 0 24 24" stroke-width="1.8"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                                    Sửa
                                </button>
                                <form method="post" asp-page-handler="Delete" class="d-inline">
                                    <input type="hidden" name="id" value="@s.Id" />
                                    <button type="submit" class="se-btn-sm se-btn-danger">
                                        <svg viewBox="0 0 24 24" stroke-width="1.8"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14H6L5 6" /><path d="M10 11v6M14 11v6" /><path d="M9 6V4h6v2" /></svg>
                                        Xóa
                                    </button>
                                </form>
                                <a class="se-btn-sm se-btn-assign"
                                   asp-page="/Subjects/Manage"
                                   asp-route-SubjectId="@s.Id">
                                    <svg viewBox="0 0 24 24" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><line x1="19" y1="8" x2="19" y2="14" /><line x1="22" y1="11" x2="16" y2="11" /></svg>
                                    Assign
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* Create Modal *@
<div class="modal fade" id="createModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Create">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Thêm môn học mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div>
                        <label class="se-field-label">Tên môn học</label>
                        <input class="form-control" name="Name" value="@Model.Name" placeholder="Nhập tên môn học..." />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div>
                        <label class="se-field-label">Mô tả</label>
                        <textarea class="form-control" name="Description" placeholder="Nhập mô tả...">@Model.Description</textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="se-btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="se-btn-primary">
                        <svg viewBox="0 0 24 24" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                        Tạo mới
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@if (ViewData["OpenCreateModal"] as string == "true")
{
    <script>
        var createModal = new bootstrap.Modal(document.getElementById('createModal'));
        createModal.show();
    </script>
}

@* Edit Modal *@
<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Update">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Chỉnh sửa môn học</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="EditSubject.Id" id="edit-id" name="EditSubject.Id" />
                    <div>
                        <label class="se-field-label">Tên môn học</label>
                        <input class="form-control" asp-for="EditSubject.Name" id="edit-name" name="EditSubject.Name" placeholder="Nhập tên môn học..." />
                    </div>
                    <div>
                        <label class="se-field-label">Mô tả</label>
                        <textarea class="form-control" asp-for="EditSubject.Description" id="edit-desc" name="EditSubject.Description" placeholder="Nhập mô tả..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="se-btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="se-btn-primary">
                        <svg viewBox="0 0 24 24" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" /><polyline points="17 21 17 13 7 13 7 21" /><polyline points="7 3 7 8 15 8" /></svg>
                        Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var editModal = document.getElementById('editModal')
        editModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget
            var id = button.getAttribute('data-id')
            var name = button.getAttribute('data-name')
            var desc = button.getAttribute('data-desc')

            document.getElementById('edit-id').value = id
            document.getElementById('edit-name').value = name
            document.getElementById('edit-desc').value = desc
        })
    </script>
}