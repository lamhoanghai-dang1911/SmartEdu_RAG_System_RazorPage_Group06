@section Scripts {
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js" asp-append-version="false"></script>
    <script src="~/js/signalr-subject.js" asp-append-version="true"></script>
    <script>
        (function () {
        var targets = document.querySelectorAll('.se-feat-card, .se-step');
        if (!('IntersectionObserver' in window)) {
        targets.forEach(function (el) { el.classList.add('se-in-view'); });
        return;
        }
        var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
        if (entry.isIntersecting) {
        entry.target.classList.add('se-in-view');
        observer.unobserve(entry.target);
        }
        });
        }, { threshold: 0.15 });
        targets.forEach(function (el) { observer.observe(el); });
        })();
    </script>
}

