@page
@model SmartEdu.RazorWeb.Pages.Lecturers.IndexModel
@{
    ViewData["Title"] = "Lecturers";
}

<style>
    .se-up-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 22px;
    }

        .se-up-header svg {
            width: 24px;
            height: 24px;
            stroke: #4A90E2;
            fill: none;
        }

        .se-up-header h2 {
            font-size: 20px;
            font-weight: 600;
            color: #0F1B2D;
            margin: 0;
        }

    .se-card {
        border: 1px solid #E2E8F0;
        border-radius: 14px;
        background: #fff;
        margin-bottom: 16px;
        overflow: hidden;
    }

    .se-card-head {
        padding: 11px 16px;
        border-bottom: 1px solid #E2E8F0;
        font-size: 11px;
        font-weight: 600;
        color: #6B7B8D;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: #F8FAFC;
    }

    .se-card-head-left {
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .se-card-head svg {
        width: 15px;
        height: 15px;
        stroke: #4A90E2;
        fill: none;
    }

    .se-alert {
        padding: 11px 15px;
        border-radius: 10px;
        font-size: 13px;
        display: flex;
        align-items: flex-start;
        gap: 9px;
        margin-bottom: 14px;
    }

        .se-alert svg {
            width: 16px;
            height: 16px;
            fill: none;
            stroke: currentColor;
            flex-shrink: 0;
            margin-top: 1px;
        }

    .se-alert-success {
        background: #EAF3DE;
        color: #3B6D11;
        border: 1px solid #C0DD97;
    }

    /* Table */
    .se-table-wrap {
        overflow-x: auto;
    }

        .se-table-wrap table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        .se-table-wrap thead tr {
            background: #F8FAFC;
            border-bottom: 1px solid #E2E8F0;
        }

        .se-table-wrap th {
            padding: 9px 16px;
            font-size: 11px;
            font-weight: 600;
            color: #6B7B8D;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-align: left;
        }

        .se-table-wrap tbody tr {
            border-bottom: 1px solid #F0F4F8;
            transition: background 0.1s;
        }

            .se-table-wrap tbody tr:last-child {
                border-bottom: none;
            }

            .se-table-wrap tbody tr:hover {
                background: #F4F8FC;
            }

        .se-table-wrap td {
            padding: 11px 16px;
            vertical-align: middle;
            color: #1A2A3A;
        }

    .se-user-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .se-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #E6F1FB;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 600;
        color: #185FA5;
        flex-shrink: 0;
    }

    .se-user-name {
        font-size: 13px;
        font-weight: 500;
        color: #1A2A3A;
    }

    .se-muted-sm {
        font-size: 12px;
        color: #AAB4C0;
    }

    .se-btn-row {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        align-items: center;
    }

    .se-btn-sm {
        padding: 5px 11px;
        font-size: 12px;
        font-weight: 500;
        border-radius: 8px;
        cursor: pointer;
        border: 1px solid #D1DCE8;
        background: #fff;
        color: #1A2A3A;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        transition: background 0.1s, border-color 0.1s, color 0.1s;
        text-decoration: none;
        white-space: nowrap;
    }

        .se-btn-sm svg {
            width: 13px;
            height: 13px;
            stroke: currentColor;
            fill: none;
        }

        .se-btn-sm:hover {
            background: #F4F8FC;
        }

    .se-btn-edit {
        border-color: #B5D4F4;
        color: #185FA5;
    }

        .se-btn-edit:hover {
            background: #E6F1FB;
        }

    .se-btn-danger {
        border-color: #F7C1C1;
        color: #A32D2D;
    }

        .se-btn-danger:hover {
            background: #FCEBEB;
        }

    .se-btn-primary {
        padding: 7px 16px;
        background: #4A90E2;
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: background 0.12s;
        text-decoration: none;
    }

        .se-btn-primary:hover {
            background: #2f76cc;
        }

        .se-btn-primary svg {
            width: 13px;
            height: 13px;
            stroke: #fff;
            fill: none;
        }

    /* Modal overrides */
    .modal-content {
        border: 1px solid #E2E8F0;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: none;
    }

    .modal-header {
        padding: 13px 18px;
        background: #F8FAFC;
        border-bottom: 1px solid #E2E8F0;
    }

        .modal-header .modal-title {
            font-size: 14px;
            font-weight: 600;
            color: #0F1B2D;
        }

    .modal-body {
        padding: 18px;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .modal-footer {
        padding: 12px 18px;
        background: #F8FAFC;
        border-top: 1px solid #E2E8F0;
        display: flex;
        justify-content: flex-end;
        gap: 8px;
    }

    .se-field-label {
        display: block;
        font-size: 12px;
        font-weight: 500;
        color: #3D4F63;
        margin-bottom: 6px;
    }

    .modal-body .form-control {
        padding: 9px 13px;
        border: 1px solid #D1DCE8;
        border-radius: 10px;
        font-size: 13px;
        color: #1A2A3A;
        background: #F8FAFC;
        outline: none;
        transition: border-color 0.12s, box-shadow 0.12s;
        box-shadow: none;
    }

        .modal-body .form-control:focus {
            border-color: #4A90E2;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(74, 144, 226, 0.10);
        }

    .se-btn-secondary {
        padding: 7px 16px;
        background: #fff;
        color: #3D4F63;
        border: 1px solid #D1DCE8;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.12s;
    }

        .se-btn-secondary:hover {
            background: #F4F8FC;
        }

    /* ===== Animations ===== */
    @@keyframes seFadeUp {
        from {
            opacity: 0;
            transform: translateY(14px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes seRowIn {
        from {
            opacity: 0;
            transform: translateY(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes seAvatarPop {
        from {
            opacity: 0;
            transform: scale(0.6);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    @@keyframes seAlertIn {
        from {
            opacity: 0;
            transform: translateY(-8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes seModalPop {
        from {
            opacity: 0;
            transform: scale(0.92) translateY(10px);
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    .se-up-header {
        animation: seFadeUp 0.4s ease-out both;
    }

    .se-alert {
        animation: seAlertIn 0.35s ease-out both;
    }

    .se-card {
        animation: seFadeUp 0.4s ease-out 0.08s both;
    }

    .se-table-wrap tbody tr {
        animation: seRowIn 0.32s ease-out both;
        transition: background 0.15s, transform 0.15s;
    }

        .se-table-wrap tbody tr:nth-child(1) {
            animation-delay: 0.04s;
        }

        .se-table-wrap tbody tr:nth-child(2) {
            animation-delay: 0.08s;
        }

        .se-table-wrap tbody tr:nth-child(3) {
            animation-delay: 0.12s;
        }

        .se-table-wrap tbody tr:nth-child(4) {
            animation-delay: 0.16s;
        }

        .se-table-wrap tbody tr:nth-child(5) {
            animation-delay: 0.20s;
        }

        .se-table-wrap tbody tr:nth-child(n+6) {
            animation-delay: 0.22s;
        }

        .se-table-wrap tbody tr:hover {
            transform: translateX(2px);
        }

    .se-avatar {
        animation: seAvatarPop 0.3s ease-out both;
        transition: transform 0.15s;
    }

    .se-table-wrap tbody tr:hover .se-avatar {
        transform: scale(1.08);
    }

    .se-btn-primary,
    .se-btn-sm,
    .se-btn-secondary {
        transition: background 0.12s, border-color 0.12s, color 0.12s, transform 0.12s;
    }

        .se-btn-primary:hover {
            transform: translateY(-1px);
        }

        .se-btn-primary:active,
        .se-btn-sm:active,
        .se-btn-secondary:active {
            transform: scale(0.96);
        }

    /* Smoother modal pop (in addition to Bootstrap's fade/scale) */
    .modal.fade .modal-dialog {
        transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.2s ease-out;
    }

    .modal.show .modal-content {
        animation: seModalPop 0.25s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    .modal-body .form-control {
        transition: border-color 0.12s, box-shadow 0.12s;
    }

    /* Respect reduced motion preference */
    @@media (prefers-reduced-motion: reduce) {
        .se-up-header,
        .se-alert,
        .se-card,
        .se-table-wrap tbody tr,
        .se-avatar,
        .modal.fade .modal-dialog,
        .modal.show .modal-content {
            animation: none !important;
            transition: none !important;
            opacity: 1 !important;
            transform: none !important;
        }
    }
</style>

<div class="se-up-header">
    <svg viewBox="0 0 24 24" stroke-width="1.8">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
        <circle cx="9" cy="7" r="4" />
        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
    </svg>
    <h2>Lecturers</h2>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="se-alert se-alert-success">
        <svg viewBox="0 0 24 24" stroke-width="1.8"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
        @TempData["SuccessMessage"]
    </div>
}

<div class="se-card">
    <div class="se-card-head">
        <div class="se-card-head-left">
            <svg viewBox="0 0 24 24" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /></svg>
            Danh sách giảng viên
        </div>
        <button class="se-btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">
            <svg viewBox="0 0 24 24" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
            Thêm mới
        </button>
    </div>

    <div class="se-table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Giảng viên</th>
                    <th>Email</th>
                    <th>Username</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in Model.Lecturers)
                {
                    var initials = string.Concat(l.FullName.Split(' ')
                        .Where(w => !string.IsNullOrEmpty(w))
                        .Take(2)
                        .Select(w => w[0].ToString().ToUpper()));

                    <tr>
                        <td>
                            <div class="se-user-cell">
                                <div class="se-avatar">@initials</div>
                                <div>
                                    <div class="se-user-name">@l.FullName</div>
                                </div>
                            </div>
                        </td>
                        <td><span class="se-muted-sm">@l.Email</span></td>
                        <td><span class="se-muted-sm">@l.Username</span></td>
                        <td>
                            <div class="se-btn-row">
                                <button class="se-btn-sm se-btn-edit"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editModal"
                                        data-id="@l.Id"
                                        data-username="@l.Username"
                                        data-fullname="@l.FullName"
                                        data-email="@l.Email">
                                    <svg viewBox="0 0 24 24" stroke-width="1.8"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                                    Sửa
                                </button>
                                <form method="post" asp-page-handler="Delete" class="d-inline">
                                    <input type="hidden" name="id" value="@l.Id" />
                                    <button type="submit" class="se-btn-sm se-btn-danger">
                                        <svg viewBox="0 0 24 24" stroke-width="1.8"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14H6L5 6" /><path d="M10 11v6M14 11v6" /><path d="M9 6V4h6v2" /></svg>
                                        Xóa
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* Create Modal *@
<div class="modal fade" id="createModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Create">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Thêm giảng viên mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div>
                        <label class="se-field-label">Username</label>
                        <input class="form-control" asp-for="NewLecturer.Username" placeholder="Nhập username..." />
                    </div>
                    <div>
                        <label class="se-field-label">Họ và tên</label>
                        <input class="form-control" asp-for="NewLecturer.FullName" placeholder="Nhập họ và tên..." />
                    </div>
                    <div>
                        <label class="se-field-label">Mật khẩu</label>
                        <input class="form-control" asp-for="NewLecturer.Password" type="password" placeholder="Nhập mật khẩu..." />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="se-btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="se-btn-primary">
                        <svg viewBox="0 0 24 24" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                        Tạo mới
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@if (ViewData["OpenCreateModal"] as string == "true")
{
    <script>
        var createModal = new bootstrap.Modal(document.getElementById('createModal'));
        createModal.show();
    </script>
}

@* Edit Modal *@
<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Update">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Cập nhật giảng viên</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="EditLecturer.Id" id="edit-id" name="EditLecturer.Id" />
                    <div>
                        <label class="se-field-label">Họ và tên</label>
                        <input class="form-control" asp-for="EditLecturer.FullName" id="edit-fullname" name="EditLecturer.FullName" placeholder="Nhập họ và tên..." />
                    </div>
                    <div>
                        <label class="se-field-label">Email</label>
                        <input class="form-control" asp-for="EditLecturer.Email" id="edit-email" name="EditLecturer.Email" placeholder="Nhập email..." />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="se-btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="se-btn-primary">
                        <svg viewBox="0 0 24 24" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" /><polyline points="17 21 17 13 7 13 7 21" /><polyline points="7 3 7 8 15 8" /></svg>
                        Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var editModal = document.getElementById('editModal')
        editModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget
            var id = button.getAttribute('data-id')
            var username = button.getAttribute('data-username')
            var fullname = button.getAttribute('data-fullname')
            var email = button.getAttribute('data-email')

            document.getElementById('edit-id').value = id
            document.getElementById('edit-fullname').value = fullname
            document.getElementById('edit-email').value = email
        })
    </script>
}

@if (ViewData["OpenEditModal"] as string == "true")
{
    <script>
        var editModal = new bootstrap.Modal(document.getElementById('editModal'));
        editModal.show();
    </script>
}
